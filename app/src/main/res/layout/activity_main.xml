<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#07090D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PuzzleBot"
        android:textSize="32sp"
        android:textColor="#4FFFB0"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number Puzzle Auto-Solver"
        android:textSize="14sp"
        android:textColor="#3A4560"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="1. GRANT OVERLAY PERMISSION"
        android:backgroundTint="#1A2030"
        android:textColor="#4FFFB0"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="2. ENABLE ACCESSIBILITY"
        android:backgroundTint="#1A2030"
        android:textColor="#4FFFB0"
        android:layout_marginBottom="16dp"/>

    <SeekBar
        android:id="@+id/seekDelay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="29"
        android:progress="5"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDelay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap delay: 600ms"
        android:textColor="#4FFFB0"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="LAUNCH PUZZLEBOT"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4FFFB0"
        android:textColor="#000000"/>

</LinearLayout>